import java.util.*;
public class Main {
    public static void main(String[] args) {
    Scanner S=new Scanner(System.in);
   int r=S.nextInt();
   int c=S.nextInt();
   int[][]a=new int[r][c];
   for(int i=0;i<r;i++){
   for(int j=0;j<c;j++){
       a[i][j]=S.nextInt();
   }
   }
   for(int i=0;i<r;i++){
       for(int j=0;j<c;j++){
           System.out.println(a[i][j]+" ");
       }
   }
   System.out.println();
    }
}
       
  
   
