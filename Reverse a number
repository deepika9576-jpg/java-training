import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner S=new Scanner(System.in);
        int n=S.nextInt();
        int rev=0;
        while(n!=0)
        {
            int digit = n % 10;
            rev = rev*10+digit;
            n =n/10;
        }
        System.out.println(rev);
    }
}
        
