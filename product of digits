import java.util.*;
class Main {
    public static void main(String[] args) {
        Scanner S=new Scanner(System.in);
       int sum=1;
       int n,s;
       n=S.nextInt();
       while(n>0)
       {
           s=n%10;
           sum=sum*s;
           n=n/10;
       }
       System.out.println(sum);
    }
}
       
