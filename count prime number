import java.util.*;
class Main {
    public static void main(String[] args) {
        Scanner S=new Scanner(System.in);
       int n,count=0;
       n=S.nextInt();
       for(int i=1;i<=n;i++){
           if(n%i==0&&i%1==0){
               count++;
           }
       }
       System.out.println(count);
    }
}
           
