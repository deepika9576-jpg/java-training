import java.util.*;
class Main {
    public static void main(String[] args) {
        Scanner S=new Scanner(System.in);
        int n,i;
        n=S.nextInt();
        for(i=1;i<=n;i++){
            if(i%4==0){
                continue;
            }
            System.out.println(i);
        }
    }
}
            
