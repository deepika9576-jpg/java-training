import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
      Scanner S=new Scanner(System.in);
        int n=S.nextInt();
        int[]a=new int[n];
        for(int i=0;i<n;i++){
            a[i]=S.nextInt();
        }
        int large=a[0];
            for(int i=1;i<n;i++) {
                if(a[i]<large){
                    large=a[i];
                }
            }
            System.out.println(+large);
    }
}
